{
  "_comment": "srs-formalizer strict mode — no GAP, no undefined, no PLACEHOLDER",
  "no-unnamed-features": "on",
  "no-unnamed-scenarios": "on",
  "no-trailing-spaces": "on",
  "no-dupe-feature-names": "on",
  "no-dupe-scenario-names": ["on", "anywhere"],
  "no-scenario-outlines-without-examples": "on",
  "no-unused-variables": "on",
  "no-empty-file": "on",
  "no-empty-background": "on",
  "no-files-without-scenarios": "on",
  "no-background-only-scenario": "on",
  "no-multiple-empty-lines": "on",
  "no-duplicate-tags": "on",
  "no-homogenous-tags": "on",
  "no-superfluous-tags": "on",
  "no-restricted-patterns": ["on", {
    "Global": ["GAP", "TODO", "FIXME", "UNDEFINED"],
    "Step": ["<THEN_PLACEHOLDER>", "<GIVEN_PLACEHOLDER>", "<WHEN_PLACEHOLDER>", "undefined", "TBD", "待定", "未定义", "待实现"]
  }],
  "no-restricted-tags": "on",
  "one-feature-per-file": "on",
  "indentation": ["on", {
    "Feature": 0,
    "Scenario": 0,
    "Step": 2,
    "Examples": 0,
    "example": 2,
    "given": 2,
    "when": 2,
    "then": 2,
    "and": 2,
    "but": 2
  }],
  "new-line-at-eof": ["on", "yes"],
  "max-scenarios-per-file": ["on", { "maxScenarios": 20, "countOutlineExamples": true }],
  "scenario-size": ["on", { "stepsPerScenario": 15 }],
  "use-and": "on",
  "keywords-in-logical-order": "on",
  "name-length": ["on", { "Feature": 100, "Scenario": 100, "Step": 150 }],
  "allowed-tags": "off",
  "required-tags": "off",
  "one-space-between-tags": "on",
  "no-partially-commented-tag-lines": "on"
}
