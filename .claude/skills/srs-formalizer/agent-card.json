{
  "protocolVersion": "1.0",
  "agentCard": {
    "name": "srs-formalizer",
    "description": "将 SRS 文档通过受门控的 Agent 流水线转化为 Cypher、Gherkin、TLA+ 与条件触发的 Lean 4 产物。默认执行 Frontend → Middle-end → Backend 依赖闭包；用户明确裁剪时记录跳过项与残余风险。",
    "version": "2.1.0",
    "provider": {
      "name": "srs-formalizer",
      "url": "https://github.com/WangHHY19931001/SRS-Formalizer"
    },
    "capabilities": {
      "input": {
        "mimeTypes": ["text/markdown", "text/html"],
        "maxSize": "10MB",
        "description": "SRS 文档（支持 .md / .html 单文件或多目录包）"
      },
      "output": {
        "formats": [
          "application/jsonl",
          "application/json",
          "text/x-cypher",
          "text/x-gherkin",
          "text/x-tla",
          "text/x-lean"
        ],
        "description": "JSONL 需求记录、Neo4j Cypher 图谱、Gherkin .feature 文件、TLA+ 规约、Lean 4 证明、审计报告、工具Schema"
      }
    },
    "taskTypes": [
      "srs-formalization",
      "knowledge-graph-generation",
      "bdd-generation",
      "tla-specification",
      "lean-proof",
      "audit-export",
      "status-reporting"
    ],
    "pipelineStages": [
      "frontend",
      "middle-end",
      "backend",
      "validation",
      "audit"
    ],
    "naturalLanguageAliases": {
      "@formalize": "Load srs-formalizer and execute the gated Frontend → Middle-end → Backend workflow",
      "@formalize-en": "Load srs-formalizer with lang=en and execute the gated workflow",
      "@generate-bdd": "Load srs-formalizer and run the dependency stages needed for BDD",
      "@validate-all": "Run the registered validation commands through index.ts"
    },
    "toolCalling": {
      "schemaCommand": "tools-schema",
      "supportedFormats": ["openai", "anthropic"],
      "cliPrefix": "npx tsx index.ts"
    },
    "sessionSupport": {
      "persistence": true,
      "stateFile": "_ctx/session.json",
      "multiTurn": true,
      "resumable": true
    },
    "security": {
      "level": "high",
      "hitlRequired": true,
      "permissions": {
        "filesystem": { "scope": ".srs_formalizer/*", "readOnly": false },
        "network": { "scope": "https://api.search.brave.com/*", "readOnly": true },
        "execute": { "scope": "npx tsx .claude/skills/srs-formalizer/scripts/index.ts <registered-command>", "readOnly": false }
      }
    },
    "endpoint": {
      "type": "cli",
      "command": "npx tsx index.ts",
      "workdir": ".srs_formalizer"
    },
    "gateConditions": [
      "validate-jsonl",
      "validate-architecture",
      "validate-cypher",
      "validate-bdd",
      "validate-tla",
      "validate-lean",
      "validate-checklist",
      "validate-glossary",
      "verify-gate"
    ],
    "skillPattern": "pipeline",
    "nestedPatterns": ["inversion", "generator", "reviewer"]
  }
}
